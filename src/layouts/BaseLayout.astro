---
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <title>RIDWAN.EXE — Game Portfolio</title>
  </head>
  <body class="bg-dark text-white font-mono">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[200] focus:px-4 focus:py-2 focus:bg-neon focus:text-dark focus:font-mono focus:text-sm focus:rounded">
      Skip to content
    </a>
    <div id="loading-screen" class="fixed inset-0 z-40 flex flex-col items-center justify-center bg-dark">
      <h1 class="text-neon text-5xl md:text-7xl font-game tracking-wider mb-8">RIDWAN.EXE</h1>
      <p class="text-gray-400 font-mono text-sm">Loading...</p>
    </div>
    <div id="main-content">
      <slot />
    </div>
  </body>
</html>
